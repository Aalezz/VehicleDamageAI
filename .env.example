# Copy to .env and edit.

# REQUIRED: long random string (e.g. `openssl rand -hex 32`)
SECRET_KEY=change_me

# Database - SQLite by default; Postgres recommended for production:
# DATABASE_URL=postgresql+psycopg2://user:pass@db:5432/vehicledamage

# Run without torch installed (mock predictions) - for dev/CI only
DEMO_MODE=false

# Plans (assessments/month)
FREE_MONTHLY_QUOTA=15
PRO_MONTHLY_QUOTA=500
BUSINESS_MONTHLY_QUOTA=10000

RATE_LIMIT_PER_MINUTE=20
ENABLE_GRADCAM=true

# --- Stripe: activate payments (money goes to YOUR Stripe account) ---
# 1. Create account at https://dashboard.stripe.com (connect your bank for payouts)
# 2. Products > create "Pro" ($25/mo + $240/yr) and "Business" ($60/mo + $600/yr)
# 3. Paste secret key + the 4 price IDs below
# 4. Developers > Webhooks > add endpoint https://YOUR_DOMAIN/api/v1/billing/webhook
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=
STRIPE_PRICE_BUSINESS_MONTHLY=
STRIPE_PRICE_BUSINESS_ANNUAL=
PUBLIC_BASE_URL=http://localhost:8000
